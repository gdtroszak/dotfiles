[core]
    pager = delta

[credential "https://github.com"]
    helper = 
    helper = !gh auth git-credential

[credential "https://gist.github.com"]
    helper = 
    helper = !gh auth git-credential

[delta]
    hyperlinks = true
    navigate = true
    light = false

[diff]
    colorMoved = default

[init]
    defaultBranch = main

[interactive]
    diffFilter = delta --color-only

[add.interactive]
    useBuiltin = false # required for git 2.37.0

[merge]
    conflictstyle = diff3

[user]
    name = Greg Troszak
    email = {{ .email }} 
